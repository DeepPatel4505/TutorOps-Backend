  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "csrfToken", "value": "" },
    { "key": "teacherUsername", "value": "teacher_demo" },
    { "key": "teacherEmail", "value": "teacher@example.com" },
    { "key": "teacherPassword", "value": "Teacher@123" },
    { "key": "studentUsername", "value": "student_demo" },
    { "key": "studentEmail", "value": "student@example.com" },
    { "key": "studentPassword", "value": "Student@123" },
